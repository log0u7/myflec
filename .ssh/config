# ~/.ssh/config

# Global defaults
IdentitiesOnly yes

# Include per-context host files
Include config.d/*

# --- Git forges ---
# Convention: plain block = default (personal) identity.
# Extra identities use a host alias (e.g. github.com-work); clone with:
#   git clone git@github.com-work:owner/repo.git
# Key naming: <forge>_<label>_<type>  (e.g. github.com_perso_ed25519)

Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/github.com_perso_ed25519

Host github.com-work
    HostName github.com
    User git
    IdentityFile ~/.ssh/github.com_work_ed25519

Host gitlab.com
    HostName gitlab.com
    User git
    IdentityFile ~/.ssh/gitlab.com_perso_ed25519

Host gitlab.com-work
    HostName gitlab.com
    User git
    IdentityFile ~/.ssh/gitlab.com_work_ed25519

Host notabug.org
    HostName notabug.org
    User git
    IdentityFile ~/.ssh/notabug.org_perso_ed25519
