# Ignore all !
*
# Except :
!README.md
!CONTRIBUTING.md
!CHANGELOG.md
!LICENSE
!AGENTS.md
!assets/
!assets/*
!myflec.exclude.lst
!.bash_*
!.bashrc.d
!.bashrc.d/*
# Re-ignore history files (excluded from .bash_* whitelist)
.bash_history*
# Runtime artifacts (present when shell is used inside the repo)
.cache/
.npm/
!.gitconfig*
!.gitconfig.d/*
!.gitignore
!.shellcheckrc
!.ssh/
!.ssh/config*
!.ssh/config.d/*
!.github/
!.github/workflows/
!.github/workflows/*.yml
!.gitlab-ci.yml
!.config/
!.config/starship.toml
!.config/lazygit/
!.config/lazygit/config.yml
